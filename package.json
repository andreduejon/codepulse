{
	"name": "@andreduejon/codepulse",
	"version": "0.5.0",
	"description": "A terminal git graph visualizer that is read-only by default",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/andreduejon/codepulse.git"
	},
	"keywords": [
		"git",
		"graph",
		"tui",
		"terminal",
		"visualizer",
		"bun",
		"solidjs"
	],
	"engines": {
		"bun": ">=1.0.0"
	},
	"type": "module",
	"bin": {
		"codepulse": "./src/index.tsx"
	},
	"files": [
		"src/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"start": "bun run src/index.tsx",
		"test": "bun test",
		"lint": "biome lint src/ tests/",
		"format": "biome format src/ tests/",
		"check": "biome check src/ tests/",
		"check:types": "tsc -p tsconfig.json --noEmit && tsc -p tests/tsconfig.json --noEmit",
		"check:fix": "biome check --write src/ tests/"
	},
	"dependencies": {
		"@opentui/core": "0.2.3",
		"@opentui/solid": "0.2.3",
		"solid-js": "1.9.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/babel__core": "^7.20.5",
		"@types/bun": "1.3.13",
		"typescript": "6.0.3"
	}
}
