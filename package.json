{
	"name": "@andreduejon/codepulse",
	"version": "0.2.0",
	"description": "A read-only terminal git graph visualizer",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/andreduejon/codepulse.git"
	},
	"keywords": [
		"git",
		"graph",
		"tui",
		"terminal",
		"visualizer",
		"bun",
		"solidjs"
	],
	"engines": {
		"bun": ">=1.0.0"
	},
	"type": "module",
	"bin": {
		"codepulse": "./src/index.tsx"
	},
	"files": [
		"src/",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"dev": "bun run src/index.tsx",
		"start": "bun run src/index.tsx",
		"test": "bun test",
		"lint": "biome lint src/ tests/",
		"format": "biome format src/ tests/",
		"check": "biome check src/ tests/",
		"check:fix": "biome check --write src/ tests/",
		"prepublishOnly": "bun run check && bun test"
	},
	"dependencies": {
		"@opentui/core": "0.1.99",
		"@opentui/solid": "0.1.99",
		"solid-js": "1.9.11"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/bun": "1.3.12"
	}
}
